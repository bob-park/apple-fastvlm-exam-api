APP_NAME=apple-fastvlm-api
LOG_LEVEL=INFO
INFERENCE_DEVICE=auto
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastvlm
STORAGE_ROOT=./storage
MODEL_ROOT=./models
FASTVLM_MODEL_ID=apple/FastVLM-0.5B
FASTVLM_LOCAL_DIR=./models/fastvlm
TEXT_EMBED_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
TEXT_EMBED_LOCAL_DIR=./models/text-embedding
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_MODEL_DIR=./models/insightface
TEXT_SIMILARITY_THRESHOLD=0.7
FACE_SIMILARITY_THRESHOLD=0.7
PAGE_SIZE_DEFAULT=20
PAGE_SIZE_MAX=100
